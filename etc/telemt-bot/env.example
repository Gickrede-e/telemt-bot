# --- Required ---

# Bot token from @BotFather (https://t.me/BotFather → /newbot)
TELEMT_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs allowed to use the bot.
# Get yours by messaging @userinfobot. Example: 12345678,87654321
TELEMT_BOT_OWNERS=


# --- Optional (defaults are sensible for a same-host telemt) ---

# TELEMT_API_BASE=http://127.0.0.1:9091
# TELEMT_METRICS_URL=http://127.0.0.1:9090/metrics

# Required only if telemt's [server.api].auth_header is set.
# Value should match what telemt expects in the Authorization header.
# TELEMT_API_AUTH=
